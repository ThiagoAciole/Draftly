{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Draftly",
  "version": "0.1.1",
  "identifier": "com.thiagoaciole.draftly",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Draftly",
        "width": 1088,
        "height": 704,
        "minWidth": 400,
        "minHeight": 560,
        "decorations": false,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: http://asset.localhost data: blob: https:; style-src 'self' 'unsafe-inline'; font-src 'self' data:; connect-src 'self' https:;"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "resources": ["resources/file-markdown.ico"],
    "fileAssociations": [
      {
        "ext": ["md"],
        "name": "Markdown",
        "description": "Arquivo Markdown",
        "mimeType": "text/markdown",
        "role": "Editor"
      },
      {
        "ext": ["json", "js", "ts", "py", "html"],
        "name": "Draftly Code",
        "description": "Arquivo de cÃ³digo compatÃ­vel com Draftly",
        "role": "Editor"
      }
    ],
    "windows": {
      "nsis": {
        "installMode": "perMachine",
        "installerHooks": "./windows/hooks.nsh"
      }
    }
  }
}
