{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Draftly",
  "version": "0.1.2",
  "identifier": "com.thiagoaciole.draftly",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Draftly",
        "width": 1088,
        "height": 704,
        "minWidth": 400,
        "minHeight": 560,
        "decorations": false,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: http://asset.localhost data: blob: https:; style-src 'self' 'unsafe-inline'; font-src 'self' data:; connect-src 'self' https:;"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "resources": [
      "resources/file-markdown.ico",
      "resources/file-txt.ico",
      "resources/file-json.ico",
      "resources/file-js.ico",
      "resources/file-ts.ico",
      "resources/file-py.ico",
      "resources/file-html.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["md"],
        "name": "Draftly.Markdown",
        "description": "Arquivo Markdown",
        "mimeType": "text/markdown",
        "role": "Editor"
      },
      {
        "ext": ["txt"],
        "name": "Draftly.Text",
        "description": "Arquivo de texto",
        "mimeType": "text/plain",
        "role": "Editor"
      },
      {
        "ext": ["json"],
        "name": "Draftly.JSON",
        "description": "Arquivo JSON",
        "mimeType": "application/json",
        "role": "Editor"
      },
      {
        "ext": ["js"],
        "name": "Draftly.JavaScript",
        "description": "Arquivo JavaScript",
        "mimeType": "text/javascript",
        "role": "Editor"
      },
      {
        "ext": ["ts"],
        "name": "Draftly.TypeScript",
        "description": "Arquivo TypeScript",
        "mimeType": "text/typescript",
        "role": "Editor"
      },
      {
        "ext": ["py"],
        "name": "Draftly.Python",
        "description": "Arquivo Python",
        "mimeType": "text/x-python",
        "role": "Editor"
      },
      {
        "ext": ["html"],
        "name": "Draftly.HTML",
        "description": "Arquivo HTML",
        "mimeType": "text/html",
        "role": "Editor"
      }
    ],
    "linux": {
      "deb": {
        "files": {
          "/usr/share/icons/hicolor/16x16/mimetypes/text-markdown.png": "icons/mimetypes/16x16/text-markdown.png",
          "/usr/share/icons/hicolor/32x32/mimetypes/text-markdown.png": "icons/mimetypes/32x32/text-markdown.png",
          "/usr/share/icons/hicolor/48x48/mimetypes/text-markdown.png": "icons/mimetypes/48x48/text-markdown.png",
          "/usr/share/icons/hicolor/64x64/mimetypes/text-markdown.png": "icons/mimetypes/64x64/text-markdown.png",
          "/usr/share/icons/hicolor/128x128/mimetypes/text-markdown.png": "icons/mimetypes/128x128/text-markdown.png",
          "/usr/share/icons/hicolor/256x256/mimetypes/text-markdown.png": "icons/mimetypes/256x256/text-markdown.png",
          "/usr/share/icons/hicolor/16x16/mimetypes/text-plain.png": "icons/mimetypes/16x16/text-plain.png",
          "/usr/share/icons/hicolor/32x32/mimetypes/text-plain.png": "icons/mimetypes/32x32/text-plain.png",
          "/usr/share/icons/hicolor/48x48/mimetypes/text-plain.png": "icons/mimetypes/48x48/text-plain.png",
          "/usr/share/icons/hicolor/64x64/mimetypes/text-plain.png": "icons/mimetypes/64x64/text-plain.png",
          "/usr/share/icons/hicolor/128x128/mimetypes/text-plain.png": "icons/mimetypes/128x128/text-plain.png",
          "/usr/share/icons/hicolor/256x256/mimetypes/text-plain.png": "icons/mimetypes/256x256/text-plain.png",
          "/usr/share/icons/hicolor/16x16/mimetypes/application-json.png": "icons/mimetypes/16x16/application-json.png",
          "/usr/share/icons/hicolor/32x32/mimetypes/application-json.png": "icons/mimetypes/32x32/application-json.png",
          "/usr/share/icons/hicolor/48x48/mimetypes/application-json.png": "icons/mimetypes/48x48/application-json.png",
          "/usr/share/icons/hicolor/64x64/mimetypes/application-json.png": "icons/mimetypes/64x64/application-json.png",
          "/usr/share/icons/hicolor/128x128/mimetypes/application-json.png": "icons/mimetypes/128x128/application-json.png",
          "/usr/share/icons/hicolor/256x256/mimetypes/application-json.png": "icons/mimetypes/256x256/application-json.png",
          "/usr/share/icons/hicolor/16x16/mimetypes/text-javascript.png": "icons/mimetypes/16x16/text-javascript.png",
          "/usr/share/icons/hicolor/32x32/mimetypes/text-javascript.png": "icons/mimetypes/32x32/text-javascript.png",
          "/usr/share/icons/hicolor/48x48/mimetypes/text-javascript.png": "icons/mimetypes/48x48/text-javascript.png",
          "/usr/share/icons/hicolor/64x64/mimetypes/text-javascript.png": "icons/mimetypes/64x64/text-javascript.png",
          "/usr/share/icons/hicolor/128x128/mimetypes/text-javascript.png": "icons/mimetypes/128x128/text-javascript.png",
          "/usr/share/icons/hicolor/256x256/mimetypes/text-javascript.png": "icons/mimetypes/256x256/text-javascript.png",
          "/usr/share/icons/hicolor/16x16/mimetypes/text-typescript.png": "icons/mimetypes/16x16/text-typescript.png",
          "/usr/share/icons/hicolor/32x32/mimetypes/text-typescript.png": "icons/mimetypes/32x32/text-typescript.png",
          "/usr/share/icons/hicolor/48x48/mimetypes/text-typescript.png": "icons/mimetypes/48x48/text-typescript.png",
          "/usr/share/icons/hicolor/64x64/mimetypes/text-typescript.png": "icons/mimetypes/64x64/text-typescript.png",
          "/usr/share/icons/hicolor/128x128/mimetypes/text-typescript.png": "icons/mimetypes/128x128/text-typescript.png",
          "/usr/share/icons/hicolor/256x256/mimetypes/text-typescript.png": "icons/mimetypes/256x256/text-typescript.png",
          "/usr/share/icons/hicolor/16x16/mimetypes/text-x-python.png": "icons/mimetypes/16x16/text-x-python.png",
          "/usr/share/icons/hicolor/32x32/mimetypes/text-x-python.png": "icons/mimetypes/32x32/text-x-python.png",
          "/usr/share/icons/hicolor/48x48/mimetypes/text-x-python.png": "icons/mimetypes/48x48/text-x-python.png",
          "/usr/share/icons/hicolor/64x64/mimetypes/text-x-python.png": "icons/mimetypes/64x64/text-x-python.png",
          "/usr/share/icons/hicolor/128x128/mimetypes/text-x-python.png": "icons/mimetypes/128x128/text-x-python.png",
          "/usr/share/icons/hicolor/256x256/mimetypes/text-x-python.png": "icons/mimetypes/256x256/text-x-python.png",
          "/usr/share/icons/hicolor/16x16/mimetypes/text-html.png": "icons/mimetypes/16x16/text-html.png",
          "/usr/share/icons/hicolor/32x32/mimetypes/text-html.png": "icons/mimetypes/32x32/text-html.png",
          "/usr/share/icons/hicolor/48x48/mimetypes/text-html.png": "icons/mimetypes/48x48/text-html.png",
          "/usr/share/icons/hicolor/64x64/mimetypes/text-html.png": "icons/mimetypes/64x64/text-html.png",
          "/usr/share/icons/hicolor/128x128/mimetypes/text-html.png": "icons/mimetypes/128x128/text-html.png",
          "/usr/share/icons/hicolor/256x256/mimetypes/text-html.png": "icons/mimetypes/256x256/text-html.png"
        }
      }
    },
    "windows": {
      "nsis": {
        "installMode": "perMachine",
        "installerHooks": "./windows/hooks.nsh"
      }
    }
  }
}
